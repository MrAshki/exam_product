PROJECT_NAME="Class-Centric AI Exam Platform API"
API_VERSION="0.1.0"
APP_DEBUG=true
SECRET_KEY=change-this-secret-key-before-use
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_NAME=exam_access_token

POSTGRES_HOST=localhost
POSTGRES_PORT=5555
POSTGRES_DB=exam_db
POSTGRES_USER=exam_user
POSTGRES_PASSWORD=exam_password
DATABASE_URL=postgresql+psycopg://exam_user:exam_password@localhost:5555/exam_db

REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_DB=0
REDIS_URL=redis://localhost:16379/0

AI_PROVIDER=mock
AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
AI_TIMEOUT_SECONDS=30
