PROJECT_NAME="Class-Centric AI Exam Platform API"
API_VERSION="0.1.0"
APP_DEBUG=true
SECRET_KEY=change-this-secret-key-before-use
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_NAME=exam_access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_PATH=/
COOKIE_DOMAIN=
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=exam_db
POSTGRES_USER=exam_user
POSTGRES_PASSWORD=exam_password
DATABASE_URL=postgresql+psycopg://exam_user:exam_password@localhost:55432/exam_db

REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_DB=0
REDIS_URL=redis://localhost:16379/0
CELERY_BROKER_URL=redis://localhost:16379/0
CELERY_RESULT_BACKEND=redis://localhost:16379/1

AI_PROVIDER=mock
AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
AI_TIMEOUT_SECONDS=30
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Class-Centric AI Exam Platform
OPENROUTER_REQUIRE_FREE_MODELS=true

AI_SUGGEST_ESSAY_RUBRIC_PRIMARY_MODEL=google/gemma-4-26b-a4b-it:free
AI_SUGGEST_ESSAY_RUBRIC_FALLBACK_MODEL=openai/gpt-oss-20b:free
AI_SUGGEST_ESSAY_RUBRIC_TEMPERATURE=0.2
AI_SUGGEST_ESSAY_RUBRIC_MAX_TOKENS=1200

AI_SHORT_ANSWER_GRADING_PRIMARY_MODEL=google/gemma-4-26b-a4b-it:free
AI_SHORT_ANSWER_GRADING_FALLBACK_MODEL=openai/gpt-oss-20b:free
AI_SHORT_ANSWER_GRADING_TEMPERATURE=0.1
AI_SHORT_ANSWER_GRADING_MAX_TOKENS=800

AI_ESSAY_GRADING_PRIMARY_MODEL=google/gemma-4-31b-it:free
AI_ESSAY_GRADING_FALLBACK_MODEL=openai/gpt-oss-20b:free
AI_ESSAY_GRADING_TEMPERATURE=0.1
AI_ESSAY_GRADING_MAX_TOKENS=1600

EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_USE_TLS=true
